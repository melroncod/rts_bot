# ===== Telegram =====
# Токен бота от @BotFather
TOKEN=123456:your-telegram-bot-token
# Прокси для Telegram (необязательно). Формат: socks5://LOGIN:PASSWORD@IP:PORT
PROXY_URL=
# ID администраторов через запятую (числовые Telegram ID), напр.: 863424729,123456789
ADMIN=863424729
# Username администратора для кнопки «Поддержка» (без @)
ADMIN_USER=your_admin_username
# Базовый URL FastAPI (используется внутри docker-сети)
FASTAPI_URL=http://api:8000

# ===== PostgreSQL =====
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=tea_catalog
# Внутри docker-compose должно совпадать с именем сервиса БД: db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== pgAdmin =====
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-strong-password
